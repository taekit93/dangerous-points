{
  "permissions": {
    "allow": [
      "Bash(npm test*)",
      "Bash(npm run *)",
      "Bash(npx playwright*)",
      "Bash(npx cypress*)",
      "Bash(npx jest*)",
      "Bash(npx vitest*)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Bash(npx prettier*)",
      "Bash(npx vite*)",
      "Bash(node *)",
      "Bash(git *)",
      "Bash(curl *)",
      "Bash(cd *)",
      "Bash(mkdir *)",
      "Bash(ls *)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/keyword-detector.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/persistent-mode.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/state-saver.mjs",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
